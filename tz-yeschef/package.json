{
  "name": "yeschef-platform",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:api": "cd apps/api && uvicorn src.api.app:app --reload --port 8000",
    "dev:dashboard": "cd apps/dashboard && npm run dev",
    "test:api": "cd apps/api && .venv/bin/python -m pytest tests/ -q",
    "lint:api": "cd apps/api && .venv/bin/ruff check src/"
  }
}
